generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())

  courses   Course[]
}

model Course {
  id         Int      @id @default(autoincrement())
  title      String
  code       String
  semester   String
  instructor String
  createdAt  DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignments   Assignment[]
  studySessions StudySession[]
}

model Assignment {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime
  status      String
  priority    String
  createdAt   DateTime @default(now())

  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model StudySession {
  id          Int      @id @default(autoincrement())
  sessionDate DateTime
  duration    Int
  topic       String
  notes       String
  createdAt   DateTime @default(now())

  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}